# MarketMasters Bot - example environment variables
# Copy this file to .env and fill in the values for local development.

# Required API keys
MARKETMASTERS_API_KEY=your_marketmasters_api_key_here
ALPACA_KEY=your_alpaca_api_key_here
ALPACA_SECRET=your_alpaca_api_secret_here

# Optional overrides (defaults are sensible for paper trading)
#ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
#MARKETMASTERS_URL=https://api.marketmasters.ai/v1/stocks/patterns

# Risk sizing
#ALPCACA_PERCENTAGE_PER_TRADE=0.02
#BREAKOUT_LIMIT_BUFFER=0.01

# Telegram notifications (optional)
# Create a bot with @BotFather and set the token below.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Chat ID to send notifications to (your user id, group id, or channel id)
TELEGRAM_CHAT_ID=987654321

# NOTE: Do NOT commit your real .env file to git. This template is safe to
# commit since it contains placeholder values.
# MarketMasters API key and URL

# Required
MARKETMASTERS_API_KEY=

# Optional: Additional parameters for MarketMasters API (e.g., filter for active bullish patterns)
MARKETMASTERS_URL=https://api.marketmasters.ai/v1/stocks/patterns
MARKETMASTERS_PARAMS='{"status":"active","bullish":"true"}'


# Alpaca API credentials and base URL
# Required
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_KEY=
ALPACA_SECRET=

# Optional: Trading parameters
ALPCACA_PERCENTAGE_PER_TRADE=0.02 # Percentage of total capital to allocate per trade (e.g., 0.02 for 2%)
BREAKOUT_LIMIT_BUFFER=0.01 # Buffer percentage to add to breakout levels (e.g., 0.01 for 1%)
